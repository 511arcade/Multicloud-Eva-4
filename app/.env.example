# Puerto del servidor Express
PORT=3000

# Conexión a PostgreSQL (BD IaaS dockerizada)
# En local: localhost. En AWS: IP privada de la EC2 de BD.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cruz_azul_erp
DB_USER=erp_app
DB_PASSWORD=erp_app_pass

# Secreto para firmar los JWT (CAMBIAR en producción)
JWT_SECRET=cambia-este-secreto-por-uno-largo-y-aleatorio
JWT_EXPIRES_IN=1h

# Habilitar segundo factor (MFA/TOTP) a nivel de aplicación
MFA_ENABLED=false
